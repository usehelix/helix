{
  "name": "@helix-agent/core",
  "version": "2.8.1",
  "description": "Agent payment intelligence — predict costs, optimize execution, fix failures. Powered by VialOS Runtime.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "helix": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "static",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "helix",
    "vialos",
    "ai-agent",
    "self-healing",
    "payment",
    "pcec",
    "gene-map",
    "agent-reliability",
    "mpp",
    "coinbase",
    "crypto",
    "budget-intelligence",
    "agent-payment"
  ],
  "vialos": {
    "compatibility": "0.3.x",
    "engine": "pcec-v6",
    "role": "vertical-product"
  },
  "author": "Adrian Bai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrianhihi/helix"
  },
  "homepage": "https://github.com/adrianhihi/helix#readme",
  "bugs": {
    "url": "https://github.com/adrianhihi/helix/issues"
  },
  "dependencies": {
    "@vial-agent/gene-map": "*",
    "@vial-agent/runtime": "^0.1.0",
    "better-sqlite3": "^11.0.0",
    "viem": "^2.47.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}

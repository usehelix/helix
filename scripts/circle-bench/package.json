{
  "name": "circle-bench",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "create-wallet": "tsx --env-file=.env src/create-wallet.ts",
    "test-transfer": "tsx --env-file=.env src/test-transfer.ts",
    "bench:bare": "tsx --env-file=.env src/run.ts --mode=bare",
    "bench:helix": "tsx --env-file=.env src/run.ts --mode=helix",
    "smoke": "tsx --env-file=.env src/run.ts --mode=bare --n-workflows=1 --n-hops=2"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
